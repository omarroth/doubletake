+
+func generateHex16() string {
+	b := make([]byte, 8)
+	rand.Read(b)
+	return strings.ToUpper(hex.EncodeToString(b))
+}
+
+func generateNumeric() string {
+	b := make([]byte, 4)
+	rand.Read(b)
+	return fmt.Sprintf("%d", binary.BigEndian.Uint32(b))
+}
